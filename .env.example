# Copy this file to .env and fill in your real values
# NEVER commit .env to version control

# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# HuggingFace / Novita (for LLM)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# RapidAPI — Indian Railways
# Get from: https://rapidapi.com/hub (search "Indian Railways IRCTC")
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenRouteService — Road/Directions
# Get from: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_key_here

# Tomorrow.io — Weather
# Get from: https://app.tomorrow.io/signup
TOMORROW_API_KEY=your_tomorrow_key_here

# Supabase — Database + Auth
# Get from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
